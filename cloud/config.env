# ─────────────────────────────────────────────────────────────────────
# Cloud Configuration for Python LTC Experiments
# ─────────────────────────────────────────────────────────────────────
# Self-contained cloud config for liquid_time_constant_networks.
# ─────────────────────────────────────────────────────────────────────

# Google Cloud project
GCP_PROJECT=liquidneuralnets

# GCS bucket (shared with Julia experiments, but results go to results-py/)
GCS_BUCKET=gs://liquidneuralnets-experiments

# Default VM settings
#
# Zone options (uncomment one):
#GCP_ZONE=us-central1-f
#GCP_ZONE=us-central1-a
GCP_ZONE=us-central1-b
#GCP_ZONE=us-central1-c
#
# VM family (uncomment one). Per-experiment .env files specify the tier
# (e.g. standard-2, highcpu-4). launch_run.sh combines: ${family}-${tier}
#GCP_VM_FAMILY=n2
#GCP_VM_FAMILY=n1                         # Gen 1 (200 vCPU quota, "CPUS")
GCP_VM_FAMILY=n4d                        # AMD Turin (150 vCPU quota)
#
# Default tier (used if experiment .env doesn't set MACHINE_TIER)
GCP_DEFAULT_TIER=standard-2               # 2 vCPU, 8 GB RAM
#
GCP_IMAGE_FAMILY=srnn-python            # Python VM image (built by build_image.sh)
GCP_USE_SPOT=false                      # Spot VMs (use relaunch_missing.sh to retry preempted)

# Concurrency limit (total running VMs for this project)
MAX_CONCURRENT_VMS=32                   # 32 × 15GB = 480GB, under 500GB HDB quota

# GitHub repo (cloned by VMs)
GITHUB_REPO=https://github.com/TomRichner/liquid_time_constant_networks.git

# Available models
MODELS=(lstm ltc ctrnn ctgru node srnn srnn-per-neuron srnn-echo srnn-no-adapt srnn-no-adapt-no-dales srnn-sfa-only srnn-std-only srnn-E-only srnn-e-only-echo srnn-e-only-per-neuron)
