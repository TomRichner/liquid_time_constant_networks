# GCP Configuration
GCP_PROJECT="liquidneuralnets"
GCP_ZONE="us-central1-b"
GCP_BUCKET="gs://liquidneuralnets-experiments"
GCP_IMAGE="srnn-pytorch"  # Custom image with PyTorch pre-installed
GCP_IMAGE_FAMILY="srnn-pytorch"
GCP_USE_SPOT=false

# VM Configuration
DEFAULT_MACHINE_TYPE_FAMILY="n4d"
DEFAULT_MACHINE_TIER="standard-2"
BOOT_DISK_SIZE="15GB"
BOOT_DISK_TYPE="pd-standard"

# Concurrency (limited by HDD quota: 500GB / 15GB = ~32)
MAX_CONCURRENT_VMS=32

# Experiment matrix
ALL_MODELS="lstm ltc ltc_rk ltc_ex ctrnn node ctgru srnn srnn_per_neuron srnn_echo srnn_no_adapt srnn_no_adapt_no_dales srnn_sfa_only srnn_std_only srnn_e_only srnn_e_only_echo srnn_e_only_per_neuron"
ALL_EXPERIMENTS="har gesture occupancy smnist traffic power ozone person cheetah"
